{
  "_comment": "Exemplo de registro do adapter H5 no Codex CLI. Copie para ~/.codex/hooks.json (ou <repo>/.codex/hooks.json) e ajuste o path do 'command'. NAO instalado automaticamente pelo onboarding -- opt-in manual. Ver docs/HARNESS-CONTRACT.md e config.toml.example para o formato TOML equivalente.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          { "type": "command", "command": "pwsh -NoProfile -File ~/.codex/hooks/adapter-guard.ps1" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Edit|Write)$",
        "hooks": [
          { "type": "command", "command": "pwsh -NoProfile -File ~/.codex/hooks/adapter-guard.ps1" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "pwsh -NoProfile -File ~/.codex/hooks/adapter-guard.ps1" }
        ]
      }
    ]
  }
}
